---
---
<div class="quant-diagram-container">
  <div class="quant-header">
    <h3>Quantisation meets Privacy</h3>
    <p>Visualising Signal-to-Noise Ratio (SNR) degradation when injecting Laplace noise into low-bit gradients.</p>
  </div>
  
  <div class="svg-wrapper">
    <svg viewBox="0 0 800 350" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="fp32Gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#6e9ce6" stop-opacity="0.2"/>
          <stop offset="100%" stop-color="#6e9ce6" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="int2Gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#c1d7ae" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#c1d7ae" stop-opacity="0"/>
        </linearGradient>
        <!-- Noise pattern -->
        <pattern id="noisePattern" width="4" height="4" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="var(--color-text-muted)" opacity="0.4" />
        </pattern>
      </defs>

      <!-- FP32 Section (Left) -->
      <g transform="translate(40, 40)">
        <text x="140" y="-10" font-family="var(--font-sans)" font-size="16" font-weight="bold" fill="var(--color-text-primary)" text-anchor="middle">FP32 Gradient Space</text>
        <text x="140" y="10" font-family="var(--font-mono)" font-size="12" fill="var(--color-text-secondary)" text-anchor="middle">High Resolution, High SNR</text>
        
        <!-- Axes -->
        <line x1="0" y1="220" x2="280" y2="220" stroke="var(--color-border)" stroke-width="2" />
        <line x1="0" y1="30" x2="0" y2="220" stroke="var(--color-border)" stroke-width="2" />
        
        <!-- Smooth Signal Curve -->
        <path d="M 0 200 C 80 200, 150 50, 280 40" fill="none" stroke="#6e9ce6" stroke-width="4" />
        <!-- Noise envelope -->
        <path d="M 0 190 C 80 190, 150 40, 280 30 L 280 50 C 150 60, 80 210, 0 210 Z" fill="url(#noisePattern)" />
        
        <!-- Annotation -->
        <line x1="200" y1="46" x2="200" y2="120" stroke="var(--color-text-muted)" stroke-dasharray="4 4" />
        <text x="200" y="135" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-muted)" text-anchor="middle">DP Noise Margin</text>
      </g>

      <!-- Divider -->
      <line x1="400" y1="20" x2="400" y2="300" stroke="var(--color-border)" stroke-dasharray="6 6" stroke-width="2" />

      <!-- INT2 Section (Right) -->
      <g transform="translate(460, 40)">
        <text x="140" y="-10" font-family="var(--font-sans)" font-size="16" font-weight="bold" fill="var(--color-text-primary)" text-anchor="middle">INT2 Quantised Space</text>
        <text x="140" y="10" font-family="var(--font-mono)" font-size="12" fill="var(--color-text-secondary)" text-anchor="middle">Low Resolution, Structured Noise</text>
        
        <!-- Axes -->
        <line x1="0" y1="220" x2="280" y2="220" stroke="var(--color-border)" stroke-width="2" />
        <line x1="0" y1="30" x2="0" y2="220" stroke="var(--color-border)" stroke-width="2" />
        
        <!-- Quantisation Levels -->
        <line x1="0" y1="40" x2="280" y2="40" stroke="var(--color-border-light)" stroke-dasharray="2 2" />
        <line x1="0" y1="100" x2="280" y2="100" stroke="var(--color-border-light)" stroke-dasharray="2 2" />
        <line x1="0" y1="160" x2="280" y2="160" stroke="var(--color-border-light)" stroke-dasharray="2 2" />
        
        <!-- Stepped Signal Curve -->
        <path d="M 0 220 L 70 220 L 70 160 L 140 160 L 140 100 L 210 100 L 210 40 L 280 40" fill="none" stroke="#c1d7ae" stroke-width="4" stroke-linejoin="round" />
        
        <!-- Exaggerated Noise envelope overlapping steps -->
        <path d="M 0 205 L 70 205 L 70 145 L 140 145 L 140 85 L 210 85 L 210 25 L 280 25 L 280 55 L 210 55 L 210 115 L 140 115 L 140 175 L 70 175 L 70 235 L 0 235 Z" fill="url(#noisePattern)" />
        
        <!-- Annotation -->
        <circle cx="140" cy="130" r="15" fill="none" stroke="var(--color-accent)" stroke-width="2" />
        <line x1="155" y1="140" x2="190" y2="170" stroke="var(--color-text-muted)" stroke-dasharray="4 4" />
        <text x="190" y="185" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-muted)" text-anchor="start">Noise completely swallows</text>
        <text x="190" y="200" font-family="var(--font-sans)" font-size="12" fill="var(--color-text-muted)" text-anchor="start">the signal step.</text>
      </g>
    </svg>
  </div>
</div>

<style>
  .quant-diagram-container {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
    margin: 2.5rem 0;
  }
  
  .quant-header h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }

  .quant-header p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .svg-wrapper {
    width: 100%;
    overflow-x: auto;
  }
</style>
