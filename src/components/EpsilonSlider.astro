---
---
<div class="epsilon-container">
  <div class="epsilon-header">
    <h3>The Privacy-Utility Trade-off</h3>
    <p>Adjust the Privacy Budget ($\epsilon$) to observe its impact on model accuracy.</p>
  </div>
  
  <div class="slider-wrapper">
    <div class="slider-labels">
      <span class="label-privacy">High Privacy (Low $\epsilon$)</span>
      <span class="label-utility">High Utility (High $\epsilon$)</span>
    </div>
    <input type="range" id="epsilonSlider" min="0.1" max="10" step="0.1" value="1.0" class="custom-slider" />
    <div class="current-value">
      Current $\epsilon$: <span id="epsilonValue" style="font-weight: 600; font-family: var(--font-mono);">1.0</span>
    </div>
  </div>

  <div id="epsilonChart" class="chart-container"></div>
</div>

<style>
  .epsilon-container {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
    margin: 2.5rem 0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }
  
  :global(.dark) .epsilon-container {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
  }

  .epsilon-header h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }

  .epsilon-header p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .slider-wrapper {
    margin-bottom: 2rem;
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .custom-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: var(--color-border);
    outline: none;
    transition: background 0.3s;
  }
  
  .custom-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
    box-shadow: 0 0 5px rgba(0,0,0,0.2);
    transition: transform 0.1s;
  }
  
  .custom-slider::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }

  .current-value {
    text-align: center;
    margin-top: 1rem;
    font-size: 1.1rem;
    color: var(--color-text-primary);
  }

  .chart-container {
    width: 100%;
    height: 300px;
    position: relative;
  }
  
  /* D3 Chart Styles */
  :global(.axis-label) {
    font-family: var(--font-sans);
    font-size: 12px;
    fill: var(--color-text-secondary);
  }
  :global(.tradeoff-line) {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 3;
    stroke-linecap: round;
  }
  :global(.tradeoff-area) {
    fill: var(--color-accent);
    opacity: 0.1;
  }
  :global(.active-point) {
    fill: var(--color-bg);
    stroke: var(--color-accent);
    stroke-width: 3;
  }
  :global(.active-lines) {
    stroke: var(--color-text-muted);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  :global(.domain), :global(.tick line) {
    stroke: var(--color-border);
  }
  :global(.tick text) {
    fill: var(--color-text-muted);
    font-family: var(--font-mono);
  }
</style>

<script>
  import * as d3 from 'd3';

  // Wait for DOM
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('epsilonChart');
    if (!container) return;

    // Dimensions
    const margin = { top: 20, right: 30, bottom: 40, left: 50 };
    const width = container.clientWidth - margin.left - margin.right;
    const height = container.clientHeight - margin.top - margin.bottom;

    // Create SVG
    const svg = d3.select(container)
      .append('svg')
      .attr('width', width + margin.left + margin.right)
      .attr('height', height + margin.top + margin.bottom)
      .append('g')
      .attr('transform', `translate(${margin.left},${margin.top})`);

    // Data generation
    // Accuracy model: A(e) = 96 - (15 / sqrt(e))
    // e=0.1 -> 96 - 47.4 = 48.6%
    // e=1.0 -> 96 - 15 = 81%
    // e=10.0 -> 96 - 4.7 = 91.3%
    const data = [];
    for (let e = 0.1; e <= 10; e += 0.1) {
      let acc = 96 - (15 / Math.sqrt(e));
      data.push({ epsilon: e, accuracy: acc });
    }

    // Scales
    const xScale = d3.scaleLog()
      .domain([0.1, 10])
      .range([0, width]);

    const yScale = d3.scaleLinear()
      .domain([40, 100])
      .range([height, 0]);

    // Axes
    const xAxis = d3.axisBottom(xScale)
      .tickValues([0.1, 0.5, 1, 2, 5, 10])
      .tickFormat(d3.format(".1f"));

    const yAxis = d3.axisLeft(yScale)
      .ticks(5)
      .tickFormat(d => `${d}%`);

    svg.append('g')
      .attr('transform', `translate(0,${height})`)
      .call(xAxis);

    svg.append('g')
      .call(yAxis);

    // Axis Labels
    svg.append('text')
      .attr('class', 'axis-label')
      .attr('x', width / 2)
      .attr('y', height + 35)
      .style('text-anchor', 'middle')
      .text('Privacy Budget (ε) - Log Scale');

    svg.append('text')
      .attr('class', 'axis-label')
      .attr('transform', 'rotate(-90)')
      .attr('x', -height / 2)
      .attr('y', -35)
      .style('text-anchor', 'middle')
      .text('Model Accuracy');

    // Area
    const areaGenerator = d3.area()
      .x(d => xScale(d.epsilon))
      .y0(height)
      .y1(d => yScale(d.accuracy))
      .curve(d3.curveMonotoneX);

    svg.append('path')
      .datum(data)
      .attr('class', 'tradeoff-area')
      .attr('d', areaGenerator);

    // Line
    const lineGenerator = d3.line()
      .x(d => xScale(d.epsilon))
      .y(d => yScale(d.accuracy))
      .curve(d3.curveMonotoneX);

    svg.append('path')
      .datum(data)
      .attr('class', 'tradeoff-line')
      .attr('d', lineGenerator);

    // Interactive elements
    const activeG = svg.append('g');

    const hLine = activeG.append('line').attr('class', 'active-lines');
    const vLine = activeG.append('line').attr('class', 'active-lines');
    const point = activeG.append('circle').attr('class', 'active-point').attr('r', 6);
    
    const accText = activeG.append('text')
      .attr('class', 'axis-label')
      .style('font-weight', '600')
      .style('fill', 'var(--color-accent)')
      .attr('dx', 10)
      .attr('dy', -10);

    // Update function
    function update(epsilon) {
      const e = parseFloat(epsilon);
      const acc = 96 - (15 / Math.sqrt(e));
      
      const cx = xScale(e);
      const cy = yScale(acc);

      point.attr('cx', cx).attr('cy', cy);
      
      hLine
        .attr('x1', 0).attr('y1', cy)
        .attr('x2', cx).attr('y2', cy);
        
      vLine
        .attr('x1', cx).attr('y1', height)
        .attr('x2', cx).attr('y2', cy);

      accText
        .attr('x', cx)
        .attr('y', cy)
        .text(`Acc: ${acc.toFixed(1)}%`);
    }

    // Initialize
    const slider = document.getElementById('epsilonSlider');
    const valDisplay = document.getElementById('epsilonValue');
    
    if (slider && valDisplay) {
      update(slider.value);
      
      slider.addEventListener('input', (e) => {
        const val = e.target.value;
        valDisplay.textContent = val;
        update(val);
      });
    }

    // Resize handler
    window.addEventListener('resize', () => {
      // For a robust implementation, redraw chart here
      // Skipping for brevity but typically necessary
    });
  });
</script>
