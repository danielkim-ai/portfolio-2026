---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="RL Portfolio"
  description="Reinforcement learning research, coursework notes, and writings."
>
  <!-- Hero -->
  <section style="margin-bottom: 3.5rem;">
    <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.75rem;">
      Reinforcement Learning Research
    </p>
    <h1>Hello, I study how agents learn.</h1>
    <p style="font-size: 1.05rem; color: var(--color-text-secondary); max-width: 36rem; margin-top: 1rem; text-decoration: none;">
      I am a researcher interested in deep reinforcement learning, policy optimization,
      and sample efficiency. This site collects my papers, lecture notes, and technical writings.
    </p>
    <div style="margin-top: 1.75rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <a
        href="/research"
        style="display:inline-block; background:var(--color-accent); color:#fff; text-decoration:none; padding: 0.55rem 1.1rem; border-radius:4px; font-size:0.85rem; font-weight:500; transition: background 0.18s;"
      >
        View Research →
      </a>
      <a
        href="/about"
        style="display:inline-block; border:1px solid var(--color-border); color:var(--color-text-secondary); text-decoration:none; padding: 0.55rem 1.1rem; border-radius:4px; font-size:0.85rem; font-weight:500;"
      >
        About Me
      </a>
    </div>
  </section>

  <hr />

  <!-- Quick links grid -->
  <section>
    <h2>Sections</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-top: 1.25rem;">
      <a href="/research"   style="text-decoration:none; padding:1.25rem 1rem; border:1px solid var(--color-border-light); border-radius:6px; background:var(--color-surface); transition: border-color 0.18s, box-shadow 0.18s;">
        <div style="font-family: var(--font-serif); font-size:1.05rem; color:var(--color-text-primary); margin-bottom:0.35rem;">Research</div>
        <div style="font-size:0.8rem; color:var(--color-text-muted);">Papers &amp; publications</div>
      </a>
      <a href="/coursework"  style="text-decoration:none; padding:1.25rem 1rem; border:1px solid var(--color-border-light); border-radius:6px; background:var(--color-surface); transition: border-color 0.18s, box-shadow 0.18s;">
        <div style="font-family: var(--font-serif); font-size:1.05rem; color:var(--color-text-primary); margin-bottom:0.35rem;">Coursework</div>
        <div style="font-size:0.8rem; color:var(--color-text-muted);">Lecture notes &amp; exercises</div>
      </a>
      <a href="/about"      style="text-decoration:none; padding:1.25rem 1rem; border:1px solid var(--color-border-light); border-radius:6px; background:var(--color-surface); transition: border-color 0.18s, box-shadow 0.18s;">
        <div style="font-family: var(--font-serif); font-size:1.05rem; color:var(--color-text-primary); margin-bottom:0.35rem;">About</div>
        <div style="font-size:0.8rem; color:var(--color-text-muted);">Background &amp; contact</div>
      </a>
    </div>
  </section>
</BaseLayout>
