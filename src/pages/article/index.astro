---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allEntries = await getCollection('article', ({ data }) => !data.draft);
const entries = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Articles"
  description="Essays and technical writings on research philosophy, approximation trade-offs, and the practice of machine learning."
>
  <header style="margin-bottom: 3rem;">
    <p style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.6rem;">
      Essays &amp; Writings
    </p>
    <h1>Articles</h1>
    <p style="color: var(--color-text-secondary); max-width: 34rem; margin-top: 0.75rem;">
      Reflections on research philosophy, statistical trade-offs, and the craft
      of building intelligent systems.
    </p>
  </header>

  {entries.length === 0 && (
    <p style="color: var(--color-text-muted); font-style: italic;">No articles published yet.</p>
  )}

  <ol style="list-style: none; padding: 0; margin: 0;">
    {entries.map((entry) => {
      const dateStr = entry.data.date.toLocaleDateString('en-US', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
      return (
        <li class="article-row">
          <time class="article-row__date" datetime={entry.data.date.toISOString()}>
            {dateStr}
          </time>
          <div class="article-row__body">
            <a href={`/article/${entry.id}`} class="article-row__title">
              {entry.data.title}
            </a>
            {entry.data.subtitle && (
              <p class="article-row__subtitle">{entry.data.subtitle}</p>
            )}
            <p class="article-row__desc">{entry.data.description}</p>
            <div class="article-row__tags">
              {entry.data.tags.map((t) => (
                <span class="tag" style="font-size:0.68rem;">{t}</span>
              ))}
            </div>
          </div>
        </li>
      );
    })}
  </ol>
</BaseLayout>

<style>
  .article-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .article-row:first-child { padding-top: 0; }

  .article-row__date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-top: 0.25rem;
    white-space: nowrap;
    text-align: right;
  }

  .article-row__body { flex: 1; }

  .article-row__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1.4;
    display: block;
    margin-bottom: 0.2rem;
    transition: color 0.15s;
  }
  .article-row__title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .article-row__subtitle {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-secondary);
    margin: 0 0 0.45rem;
  }

  .article-row__desc {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0 0 0.6rem;
    max-width: 38rem;
  }

  .article-row__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  @media (max-width: 560px) {
    .article-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .article-row__date {
      text-align: left;
    }
  }
</style>
