---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BayesianRlDiagram from '../../components/BayesianRlDiagram.astro';
import PrivacyRlDiagram from '../../components/PrivacyRlDiagram.astro';

const allEntries = await getCollection('research', ({ data }) => !data.draft);
const entries = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Research"
  description="Publications and research projects in reinforcement learning and machine learning."
>
  <header style="margin-bottom: 3rem;">
    <p style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.6rem;">
      Research Roadmap &amp; Interests
    </p>
    <h1>Future Horizons &amp; Research Directions</h1>
    <p style="color: var(--color-text-secondary); max-width: 40rem; margin-top: 1rem; font-size: 1.05rem; line-height: 1.7;">
      My academic pursuit lies at the intersection of rigorous statistical inference and high-performance machine learning, with a particular focus on the following domains:
    </p>
  </header>

  <div class="research-cards-container">
    <!-- Direction 1: Bayesian RL & Distributional Optimisation -->
    <div class="research-card">
      <h3>Bayesian RL &amp; Distributional Optimisation</h3>
      <div class="research-card__tags">
        <span class="tag">Variational Inference</span>
        <span class="tag">Posterior Approximation</span>
        <span class="tag">Epistemic Uncertainty</span>
      </div>
      
      <BayesianRlDiagram />

      <p>
        Interrogating the convergence of Bayesian statistics and reinforcement learning to maximise sample efficiency within high-dimensional state spaces. By transitioning beyond conventional point estimation, I am investigating the structural guarantees of uncertainty estimation. This entails leveraging variational inference for robust posterior approximation and quantifying epistemic uncertainty within a Variational Actor-Critic framework.
      </p>
      <div class="research-card__diagram-link">
        <strong>Symbolic Nexus:</strong> This trajectory sits firmly at the intersection of Stats and RL, bridging rigorous statistical probability with dynamic environment navigation.
      </div>
      <div class="research-card__challenge">
        Challenge: Balancing Sample Efficiency with Computational Complexity in High-dimensional Stochastic Environments.
      </div>
    </div>

    <!-- Direction 2: Privacy-Preserving Offline RL -->
    <div class="research-card">
      <h3>Privacy-Preserving Offline RL</h3>
      <div class="research-card__tags">
        <span class="tag">Differential Privacy</span>
        <span class="tag">Machine Unlearning</span>
        <span class="tag">Optimisation under Constraints</span>
      </div>
      
      <PrivacyRlDiagram />

      <p>
        Exploring the structural guarantees of $(\epsilon, \delta)$-Differential Privacy within offline reinforcement learning, particularly concerning sensitive medical and financial logs. Rather than relying on naive noise injection, the objective is to architect utility-optimised mechanisms that negotiate the privacy-utility trade-off via precise optimisation under constraints. This encompasses integrating machine unlearning for efficient policy updates and ensuring robust policy evaluation under stringent privacy boundaries.
      </p>
      <div class="research-card__diagram-link">
        <strong>Symbolic Nexus:</strong> This pursuit demands a seamless integration across all three vertices of the trilemma (CS × Stats × RL), embedding systemic privacy constraints directly into statistical and sequential decision domains.
      </div>
      <div class="research-card__challenge">
        Challenge: Architecting Utility-Optimised Mechanisms without Compromising $(\epsilon, \delta)$-Differential Privacy Guarantees.
      </div>
    </div>
  </div>

  <div style="margin-top: 5rem; margin-bottom: 2rem;">
    <h2 style="font-family: var(--font-sans); font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--color-text-primary);">Publications &amp; Projects</h2>
    <p style="color: var(--color-text-muted); font-size: 0.9rem;">Peer-reviewed papers, preprints, and ongoing implementations.</p>
  </div>

  {entries.length === 0 && (
    <p style="color: var(--color-text-muted); font-style: italic;">No publications yet.</p>
  )}

  <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0;">
    {entries.map((entry, i) => {
      const dateStr = entry.data.date.toLocaleDateString('en-US', {
        year: 'numeric', month: 'long',
      });
      const arxivUrl = entry.data.arxiv
        ? `https://arxiv.org/abs/${entry.data.arxiv}`
        : null;
      return (
        <li class="research-item">
          <div class="research-item__num">[{entries.length - i}]</div>
          <div class="research-item__body">
            <a href={`/research/${entry.id}`} class="research-item__title">
              {entry.data.title}
            </a>
            {entry.data.authors && (
              <p class="research-item__authors">
                {entry.data.authors.join(', ')}
              </p>
            )}
            <p class="research-item__meta">
              {entry.data.venue && (
                <span class="research-item__venue">{entry.data.venue}</span>
              )}
              {entry.data.venue && <span class="research-item__sep">·</span>}
              <time datetime={entry.data.date.toISOString()}>{dateStr}</time>
            </p>
            <div class="research-item__links">
              {entry.data.tags.slice(0, 4).map((t) => (
                <span class="tag" style="font-size:0.68rem;">{t}</span>
              ))}
              {arxivUrl && (
                <a
                  href={arxivUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="research-item__extlink"
                >
                  arXiv ↗
                </a>
              )}
              {entry.data.doi && (
                <a
                  href={entry.data.doi}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="research-item__extlink"
                >
                  DOI ↗
                </a>
              )}
              {entry.data.pdfUrl && (
                <a
                  href={entry.data.pdfUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="research-item__extlink research-item__extlink--pdf"
                >
                  PDF ↗
                </a>
              )}
            </div>
          </div>
        </li>
      );
    })}
  </ol>
</BaseLayout>

<style>
  .research-item {
    display: flex;
    gap: 1.1rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .research-item:first-child { padding-top: 0; }

  .research-item__num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    padding-top: 0.2rem;
    white-space: nowrap;
    flex-shrink: 0;
    width: 2rem;
    text-align: right;
  }

  .research-item__body { flex: 1; }

  .research-item__title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-primary);
    text-decoration: none;
    line-height: 1.45;
    display: block;
    margin-bottom: 0.35rem;
    transition: color 0.15s;
  }
  .research-item__title:hover { color: var(--color-accent); text-decoration: none; }

  .research-item__authors {
    font-size: 0.83rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.3rem;
  }

  .research-item__meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .research-item__venue {
    font-weight: 600;
    color: var(--color-accent);
  }

  .research-item__sep { opacity: 0.4; }

  .research-item__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .research-item__extlink {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .research-item__extlink:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .research-item__extlink--pdf {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    background-color: var(--color-accent-light);
  }

  /* Research Cards Styles */
  .research-cards-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .research-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  :global(.dark) .research-card {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
  }

  .research-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.08);
  }
  
  :global(.dark) .research-card:hover {
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .research-card h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--color-text-primary);
  }

  .research-card__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  
  .research-card__tags .tag {
    font-size: 0.75rem;
    background-color: transparent;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-muted);
  }

  .research-card p {
    font-size: 0.98rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .research-card__diagram-link {
    font-size: 0.88rem;
    font-family: var(--font-sans);
    color: var(--color-text-muted);
    font-style: italic;
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
  }

  .research-card__challenge {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: 0.5rem;
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.5;
  }
</style>
