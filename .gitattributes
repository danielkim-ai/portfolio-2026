# Normalize line endings to LF in the repository
* text=auto eol=lf

# Binary files
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text eol=lf
*.woff2 binary
*.woff  binary
*.ttf   binary
*.eot   binary

# Lock files (don't normalize)
package-lock.json text eol=lf
